# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Next.js build output
# =============================================================================
.next/
out/
build/
dist/

# =============================================================================
# Environment variables (SECRETS)
# Never commit real API keys / Firebase config / passwords.
# .env.example is kept in the repo as a template.
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Firebase / Google Cloud service accounts (server-side secrets)
# =============================================================================
serviceAccount*.json
*-firebase-adminsdk-*.json
firebase-debug.log*
firestore-debug.log*
ui-debug.log*
.firebase/
.firebaserc.local

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# Testing / coverage
# =============================================================================
coverage/
.nyc_output/
*.lcov

# =============================================================================
# TypeScript
# =============================================================================
*.tsbuildinfo
next-env.d.ts

# =============================================================================
# Deployment platforms
# =============================================================================
.vercel
.netlify

# =============================================================================
# Editor / IDE
# =============================================================================
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS generated
# =============================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# Misc
# =============================================================================
.cache/
.turbo/
.parcel-cache/
.eslintcache
blur-reveal.md
vertical-tabs.md