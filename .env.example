# =============================================================================
# Firebase Web App Configuration
# =============================================================================
# Másold át ezt a fájlt .env.local néven és töltsd ki a Firebase Console-ból:
#   https://console.firebase.google.com/
#   -> Project settings -> Your apps -> Web app -> SDK setup and configuration
#
# FONTOS:
# - A NEXT_PUBLIC_ prefixű változók a kliens JS bundle-be kerülnek.
#   Ez a Firebase Web SDK-nál rendben van: a web API key publikus,
#   a biztonságot a Firestore Security Rules + Firebase Auth biztosítja.
# - Admin SDK service-account JSON-t SOHA ne tegyél .env.local-ba és
#   ne commitold a repo-ba. Külön szerver oldali környezeti változóként
#   (pl. Vercel/Cloud Run secret) kezeld.
# =============================================================================

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# =============================================================================
# Firebase Admin SDK (csak a seed-scripthez, szerver oldalon)
# =============================================================================
# A service account JSON-t Firebase Console -> Project settings -> Service
# accounts -> Generate new private key menüpontban kapod meg.
# NE commitold a repo-ba (a .gitignore alapból kizárja a serviceAccount*.json-t).
#
# Példa használat:
#   FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json \
#   SEED_CLIENT_IDS=uid1,uid2 \
#   pnpm seed:workouts
# =============================================================================

FIREBASE_SERVICE_ACCOUNT_PATH=
SEED_CLIENT_IDS=
SEED_WORKOUT_DATE=
